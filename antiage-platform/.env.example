# Database
DATABASE_URL="postgresql://user:password@localhost:5432/antiage?schema=public"

# Resend (email)
RESEND_API_KEY="re_xxxxxxxxxxxx"

# Arcjet (security)
ARCJET_KEY="ajkey_xxxxxxxxxxxx"

# Inngest (email queues)
INNGEST_EVENT_KEY="xxxxxxxxxxxx"
INNGEST_SIGNING_KEY="xxxxxxxxxxxx"

# Telegram Bot
TELEGRAM_BOT_TOKEN="xxxxxxxxxxxx"
TELEGRAM_WEBHOOK_SECRET="xxxxxxxxxxxx"

# Analytics (Umami)
NEXT_PUBLIC_UMAMI_WEBSITE_ID="xxxxxxxxxxxx"
NEXT_PUBLIC_UMAMI_URL="https://your-umami.com"

# Sentry
SENTRY_DSN="https://xxxxxxxxxxxx@sentry.io/xxxxxxxxxxxx"

# Cloudinary
CLOUDINARY_CLOUD_NAME="xxxxxxxxxxxx"
CLOUDINARY_API_KEY="xxxxxxxxxxxx"
CLOUDINARY_API_SECRET="xxxxxxxxxxxx"

# JWT Secret (quiz results)
JWT_SECRET="your-random-secret-key-here"
